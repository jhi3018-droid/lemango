rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 인증 여부만 확인 (users/{uid} self-read에 한정)
    function isAuth() { return request.auth != null; }

    // 본인 사용자 문서 조회 헬퍼
    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // 승인된 사용자만 통과 (대부분의 컬렉션 기본 게이트)
    function isApproved() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).status == 'approved';
    }

    // 관리자(grade 3 이상): 관리자/시스템관리자/대표이사 모두 포함
    function isAdmin() {
      return isApproved() && userDoc(request.auth.uid).grade >= 3;
    }

    // sharedData — 상품/행사/업무/설정 등 핵심 데이터
    // ⚠️ Firestore 규칙은 "가장 구체적 규칙 우선"이 아니라 OR-합집합이다.
    //   따라서 아래 sharedData/stores 를 admin-write 로 제한하려면, 이 일반 규칙에서
    //   docId == 'stores' 를 명시적으로 제외해야 한다(그렇지 않으면 approved 누구나 stores 쓰기 가능).
    match /sharedData/{docId} {
      allow read: if isApproved();
      allow write: if isApproved() && docId != 'stores';
    }

    // sharedData/stores — 매장 설정(POS). 조회는 승인자 전원, 쓰기는 관리자(grade>=3)만.
    match /sharedData/stores {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // storeStock — 매장별 재고 (POS Phase 1d). storeStock/{storeId}_{productCode}
    //   read : 승인자 전원 (재고 조회는 전 직원 개방 — POS 권한 방침)
    //   write: 관리자(전 매장) OR 본인 배정 매장(storeId 일치, 비어있지 않을 때)
    //   ⚠️ 모든 write 는 storeId 필드를 포함해야 함(writeStoreStock 이 항상 포함).
    match /storeStock/{docId} {
      allow read: if isApproved();
      allow write: if isApproved() && (
        isAdmin() ||
        (request.resource.data.storeId != '' &&
         request.resource.data.storeId == userDoc(request.auth.uid).storeId)
      );
    }

    // storeSales — 매장 매출 원장 (POS Phase 3+). 지금은 규칙 형태만 정의(전방 호환).
    //   append-only: 취소/환불은 새 레코드로 기록, 기존 레코드 수정/삭제 금지.
    //   create: 관리자 OR 본인 매장. update/delete: 전면 금지.
    match /storeSales/{docId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isAdmin() ||
        (request.resource.data.storeId != '' &&
         request.resource.data.storeId == userDoc(request.auth.uid).storeId)
      );
      allow update, delete: if false;
    }

    // storeInbound — 매장 입고 이력 (POS Phase 2c). 라인당 1 doc, append-only 감사 이력.
    //   read : 승인자 전원 (입고 이력 조회 개방 — 권한 방침)
    //   create: 관리자(전 매장) OR 본인 매장(storeId 일치, 비어있지 않을 때) — storeStock/storeSales 와 동일 게이트
    //   update/delete: 전면 금지 (불변 감사 이력)
    match /storeInbound/{docId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isAdmin() ||
        (request.resource.data.storeId != '' &&
         request.resource.data.storeId == userDoc(request.auth.uid).storeId)
      );
      allow update, delete: if false;
    }

    // notifications
    match /notifications/{docId} {
      allow read, write: if isApproved();
    }

    // editLocks
    match /editLocks/{docId} {
      allow read, write: if isApproved();
    }

    // watches
    match /watches/{docId} {
      allow read, write: if isApproved();
    }

    // users
    match /users/{uid} {
      // 본인 문서는 미승인(pending) 상태에서도 읽을 수 있어야 함 (승인 대기 화면)
      // 다른 사람 문서는 승인된 사용자만 조회 가능
      allow read: if isAuth() && (request.auth.uid == uid || isApproved());

      // 회원가입 시 본인 doc 최초 생성 — 안전한 기본값 강제
      //  - grade는 반드시 1 (담당자, 최저 등급) — 자기 자신을 관리자로 만들 수 없음
      //  - status는 반드시 'pending' — 자기 자신을 승인 처리할 수 없음
      //  ※ 첫 사용자 자동 셋업(auth.js의 grade=4/approved)은 이 규칙에 의해 차단됩니다.
      //    프로덕션에서는 이미 첫 사용자가 존재하므로 영향 없음.
      //    초기 부트스트랩이 필요한 경우 Firebase 콘솔에서 수동으로 첫 관리자 doc 시드 필요.
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.grade == 1
        && request.resource.data.status == 'pending';

      // 업데이트:
      //  - 본인이 본인 doc를 수정할 때는 grade/status 변경 금지 (권한 상승 차단)
      //  - 관리자(grade>=3)는 모든 필드 변경 가능 (등급/상태 변경 포함)
      allow update: if isAuth() && (
        (request.auth.uid == uid
          && request.resource.data.grade == resource.data.grade
          && request.resource.data.status == resource.data.status)
        || isAdmin()
      );

      // 회원 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // leaves — 연차 신청/내역
    match /leaves/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      // 본인(uid 필드 일치) 또는 관리자만 삭제
      allow delete: if isApproved() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
    }

    // leaveQuotas — 연차 한도
    match /leaveQuotas/{uid} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // attendance — 출퇴근
    match /attendance/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if false;
    }

    // activityLogs — 활동 로그 (감사 추적, 읽기만 허용)
    match /activityLogs/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if false;
    }

    // posts — 게시판
    match /posts/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isApproved() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.authorUid == request.auth.uid ||
        isAdmin()
      );
    }

    // comments — 모달 댓글
    match /comments/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      // 작성자(uid 필드) 또는 관리자(grade>=3)만 삭제 — 클라이언트 정책과 일치
      allow delete: if isApproved() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
    }

    // personalSchedules — 개인일정 (작성자 전용 데이터)
    match /personalSchedules/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      // 작성자 본인만 수정/삭제 (관리자도 불가)
      allow update: if isApproved() && resource.data.createdBy == request.auth.uid;
      allow delete: if isApproved() && resource.data.createdBy == request.auth.uid;
    }

    // backups — 백업 데이터 (시스템 관리자 이상)
    match /backups/{type}/items/{itemId} {
      allow read: if isApproved();
      allow write: if isApproved() && userDoc(request.auth.uid).grade >= 4;
    }

    // salaries — 급여 (민감 정보)
    // read: 본인 doc 또는 관리자(grade>=3)
    // write: 관리자(grade>=3)만
    match /salaries/{doc} {
      allow read: if isApproved() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
