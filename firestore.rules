rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 로그인된 사용자만 읽기/쓰기 허용
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /comments/{commentId} {
      allow read, write: if request.auth != null;
    }
    match /activityLogs/{logId} {
      allow read, write: if request.auth != null;
    }
    match /posts/{postId} {
      allow read, write: if request.auth != null;
    }
    match /personalSchedules/{docId} {
      allow read, write: if request.auth != null;
    }
    match /attendance/{docId} {
      allow read, write: if request.auth != null;
    }
    match /leaves/{docId} {
      allow read, write: if request.auth != null;
    }
    match /leaveQuotas/{docId} {
      allow read, write: if request.auth != null;
    }
    match /backups/{type}/items/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /sharedData/{docId} {
      allow read, write: if request.auth != null;
    }
    match /products/{docId} {
      allow read, write: if request.auth != null;
    }
    // 급여: 본인 급여는 read 가능, grade>=3 (관리자) 만 read/write 전체 가능
    match /salaries/{docId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3);
      allow create, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3;
    }
    // 알림: 인증된 사용자는 누구나 생성 가능(다른 사용자에게 멘션 전송),
    // 본인 uid 필드 일치 문서만 read/update/delete 가능
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null
        && resource != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid is string;
    }
    // 편집 잠금: 인증된 사용자 누구나 read/write (다중 사용자 편집 충돌 방지)
    match /editLocks/{lockId} {
      allow read, write: if request.auth != null;
    }
    // 워치(관심 등록): 모든 사용자가 read (notifyWatchers에서 다른 사용자 워치도 조회),
    // 본인 uid 문서만 write
    match /watches/{watchId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
