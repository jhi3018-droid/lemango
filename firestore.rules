rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    // sharedData — 상품/행사/업무/설정 등 핵심 데이터
    match /sharedData/{docId} {
      allow read, write: if isAuth();
    }

    // notifications
    match /notifications/{docId} {
      allow read, write: if isAuth();
    }

    // editLocks
    match /editLocks/{docId} {
      allow read, write: if isAuth();
    }

    // watches
    match /watches/{docId} {
      allow read, write: if isAuth();
    }

    // users
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3);
      allow delete: if false;
    }

    // leaves
    match /leaves/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // leaveQuotas
    match /leaveQuotas/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3;
    }

    // attendance
    match /attendance/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // activityLogs
    match /activityLogs/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // posts
    match /posts/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.authorUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3);
    }

    // comments
    match /comments/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // personalSchedules
    match /personalSchedules/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // backups
    match /backups/{type}/items/{itemId} {
      allow read: if isAuth();
      allow write: if isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 4;
    }

    // salaries — 급여 (민감 정보)
    // read: 본인 doc 또는 관리자(grade>=3)
    // write: 관리자(grade>=3)만
    match /salaries/{doc} {
      allow read: if isAuth() && (
        resource.data.uid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3);
      allow create: if isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3;
      allow update, delete: if isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grade >= 3;
    }
  }
}
