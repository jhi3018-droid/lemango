rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 인증 여부만 확인 (users/{uid} self-read에 한정)
    function isAuth() { return request.auth != null; }

    // 본인 사용자 문서 조회 헬퍼
    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // 승인된 사용자만 통과 (대부분의 컬렉션 기본 게이트)
    function isApproved() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).status == 'approved';
    }

    // 관리자(grade 3 이상): 관리자/시스템관리자/대표이사 모두 포함
    function isAdmin() {
      return isApproved() && userDoc(request.auth.uid).grade >= 3;
    }

    // sharedData — 상품/행사/업무/설정 등 핵심 데이터
    // ⚠️ Firestore 규칙은 "가장 구체적 규칙 우선"이 아니라 OR-합집합이다.
    //   따라서 아래 sharedData/stores 를 admin-write 로 제한하려면, 이 일반 규칙에서
    //   docId == 'stores' 를 명시적으로 제외해야 한다(그렇지 않으면 approved 누구나 stores 쓰기 가능).
    match /sharedData/{docId} {
      allow read: if isApproved();
      allow write: if isApproved() && docId != 'stores' && docId != 'inboundTypes' && docId != 'storeDiscounts';
    }

    // sharedData/stores — 매장 설정(POS). 조회는 승인자 전원, 쓰기는 관리자(grade>=3)만.
    match /sharedData/stores {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // sharedData/inboundTypes — 입고 유형 설정(POS). 조회는 승인자 전원, 쓰기는 관리자(grade>=3)만. (stores 와 동일 OR-union 패턴)
    match /sharedData/inboundTypes {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // sharedData/storeDiscounts — 매장 할인 규칙(POS Phase 5-1). 조회는 승인자 전원(판매 시 적용), 쓰기는 관리자만. (stores/inboundTypes 와 동일 OR-union 패턴)
    match /sharedData/storeDiscounts {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // storeStock — 매장별 재고 (POS Phase 1d). storeStock/{storeId}_{productCode}
    //   read : 승인자 전원 (재고 조회는 전 직원 개방 — POS 권한 방침)
    //   write: 관리자(전 매장) OR 본인 배정 매장(storeId 일치, 비어있지 않을 때)
    //   ⚠️ 모든 write 는 storeId 필드를 포함해야 함(writeStoreStock 이 항상 포함).
    match /storeStock/{docId} {
      allow read: if isApproved();
      allow write: if isApproved() && (
        isAdmin() ||
        (request.resource.data.storeId != '' &&
         request.resource.data.storeId == userDoc(request.auth.uid).storeId)
      );
    }

    // storeSales — 매장 매출 원장 (POS Phase 3a). append-only 거래 단위 문서(영수증형).
    //   read : 승인자 전원 (매출 조회 개방 — 권한 방침)
    //   create: 관리자 OR 본인 매장(storeId 일치, 비어있지 않을 때). type∈['sale','void'].
    //           void 레코드는 사유 필수 + voidedBy==본인(위조 방지) 추가 강제.
    //   update/delete: 전면 금지 → 취소도 새 레코드(역기록). ⚠️ 결정적 id 'void_{saleDocId}' 라
    //           동일 판매 2번째 취소 write 는 기존 doc update 로 평가 → 여기서 거부 → double-void 구조적 불가.
    match /storeSales/{docId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && (isAdmin() ||
            (request.resource.data.storeId != '' &&
             request.resource.data.storeId == userDoc(request.auth.uid).storeId))
        && (request.resource.data.type == 'sale' || request.resource.data.type == 'void')
        && (request.resource.data.type != 'void' || (
             request.resource.data.voidReason is string
             && request.resource.data.voidReason.size() > 0
             && request.resource.data.voidedBy == request.auth.uid
           ));
      allow update, delete: if false;
    }

    // storeInbound — 매장 입고 이력 (POS Phase 2c). 라인당 1 doc, 감사 이력.
    //   read : 승인자 전원 (입고 이력 조회 개방 — 권한 방침)
    //   create: 관리자(전 매장) OR 본인 매장(storeId 일치, 비어있지 않을 때) — storeStock/storeSales 와 동일 게이트
    //   update: 입고 취소(cancellation)만 정밀 허용 — 관리자 OR 본인 매장, 미취소→취소 1회성, 사유 필수(서버강제), 취소 필드만 변경 가능
    //   delete: 전면 금지 (원본 레코드 삭제 불가 — 감사 보존)
    match /storeInbound/{docId} {
      allow read: if isApproved();
      allow create: if isApproved() && (
        isAdmin() ||
        (request.resource.data.storeId != '' &&
         request.resource.data.storeId == userDoc(request.auth.uid).storeId)
      );
      allow update: if isApproved()
        && (isAdmin() ||
            (resource.data.storeId != '' &&
             resource.data.storeId == userDoc(request.auth.uid).storeId))
        && resource.data.get('cancelled', false) != true            // 1회성: 이미 취소된 건 재취소 불가 (⚠️ .get(k,default) — 미존재 필드 직접 접근은 규칙에서 에러→거부되므로 필수)
        && request.resource.data.cancelled == true                  // 이 업데이트는 반드시 '취소' 여야 함
        && request.resource.data.cancelReason is string
        && request.resource.data.cancelReason.size() > 0            // 사유 서버 강제(빈값 불가)
        && request.resource.data.cancelledBy == request.auth.uid    // 감사 무결성: 취소자 위조 방지(WHO=실제 인증 사용자)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['cancelled','cancelledAt','cancelledBy','cancelledByName','cancelReason']);  // 취소 필드만 변경 허용
      allow delete: if false;
    }

    // replenishOrders — 매장 보충 발주(요청) 원장 (POS R1). 발주 = 요청 문서 → 🔴 재고 무접촉(storeStock/storeInbound/storeSales 전혀 안 건드림).
    //   doc id = roNo(결정적) → 재제출 set 은 기존 doc 'update' 로 평가 → 아래 update 규칙(취소/체크 한정) 에 걸려 거부 → exactly-once(중복 발주 구조적 불가).
    //   read  : 승인자 전원 (물류 뷰 R2 = 전 직원 v1 · 본인 발주 조회 포함 — 권한 방침)
    //   create: 관리자(전 매장) OR 본인 배정 매장(storeId 일치, 비어있지 않을 때) + shape(status='requested', 두 체크 false). (storeStock/storeSales 와 동일 게이트)
    //           ⚠️ 규칙은 lines[] 배열 내부/합계를 검증 못 함 → 라인 내용은 클라(buildReplenishDoc) 가 authoritative(정직한 한계).
    //   update: (a) 발주 취소 — 관리자 OR 본인 매장, resource.status=='requested' && shipChecked==false 일 때만(발송되면 취소 불가), 취소 4필드만, 새 status='cancelled', cancelledBy==본인, 사유 필수.
    //           (b) 진행 체크(R2 확인✓/발송✓) — 승인자 전원(물류), 각 체크 3필드만, false→true 단방향(정직한 진행 마커 — 되돌리기 불가), setter==본인.
    //   delete: 전면 금지 (감사 보존). ⚠️ .get(k,default) — 미존재 필드 직접 접근은 규칙에서 에러→거부되므로 필수(레거시/부분 문서 방어).
    match /replenishOrders/{docId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && (isAdmin() ||
            (request.resource.data.storeId != '' &&
             request.resource.data.storeId == userDoc(request.auth.uid).storeId))
        && request.resource.data.status == 'requested'
        && request.resource.data.confirmChecked == false
        && request.resource.data.shipChecked == false;
      allow update: if isApproved() && (
        // (a) 발주 취소 — 미발송(shipChecked==false) & 요청 상태일 때만. 취소 필드만 변경. 1회성(취소된 건 status!='requested' 라 재진입 불가).
        (
          (isAdmin() ||
           (resource.data.storeId != '' &&
            resource.data.storeId == userDoc(request.auth.uid).storeId))
          && resource.data.get('status', '') == 'requested'
          && resource.data.get('shipChecked', false) == false
          && request.resource.data.status == 'cancelled'
          && request.resource.data.cancelledBy == request.auth.uid          // 감사 무결성: 취소자 위조 방지
          && request.resource.data.cancelledReason is string
          && request.resource.data.cancelledReason.size() > 0               // 사유 서버 강제(빈값 불가)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status','cancelledBy','cancelledAt','cancelledReason'])
        ) ||
        // (b-1) 확인 체크(R2) — 요청 상태에서만, false→true 단방향, 확인 3필드만, setter==본인. (되돌리기 없음 = 정직한 진행 마커; 취소된 발주엔 체크 불가)
        (
          resource.data.get('status', '') == 'requested'
          && resource.data.get('confirmChecked', false) == false
          && request.resource.data.confirmChecked == true
          && request.resource.data.confirmCheckedBy == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['confirmChecked','confirmCheckedBy','confirmCheckedAt'])
        ) ||
        // (b-2) 발송 체크(R2) — 요청 상태에서만, false→true 단방향, 발송 3필드만, setter==본인. shipChecked=true 되면 (a) 취소 경로 봉쇄(요청중 lifecycle 종료).
        (
          resource.data.get('status', '') == 'requested'
          && resource.data.get('shipChecked', false) == false
          && request.resource.data.shipChecked == true
          && request.resource.data.shipCheckedBy == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['shipChecked','shipCheckedBy','shipCheckedAt'])
        )
      );
      allow delete: if false;
    }

    // salesOrders — 매출 관리 L1 주문 원장 (원본 주문내역 → 병합). salesOrders/{채널_주문번호}
    //   read : 승인자 전원 (매출 조회는 전 직원 개방 방침)
    //   write: 관리자(grade>=3)만 (업로드=admin 주도). 병합=set(merge-in-memory) → create/update 모두 관리자.
    //   ⚠️ 규칙은 배열 내부/문서 간 합계 정합을 검증 불가 — 병합 정확성은 클라 트랜잭션(멱등 set) 이 authoritative.
    match /salesOrders/{docId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // salesUploads — 매출 업로드 내역(감사/추적). 관리자만 기록.
    match /salesUploads/{docId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // salesD/salesW/salesM — 매출 집계(L2 일별 · L3 주/월×채널그룹, Phase 2). L1 에서 재도출되는 파생 데이터.
    //   read : 승인자 전원 (매출 조회 전 직원 방침) · write: 관리자(재계산 도구가 재도출·overwrite)
    match /salesD/{docId} { allow read: if isApproved(); allow write: if isAdmin(); }
    match /salesW/{docId} { allow read: if isApproved(); allow write: if isAdmin(); }
    match /salesM/{docId} { allow read: if isApproved(); allow write: if isAdmin(); }

    // notifications
    match /notifications/{docId} {
      allow read, write: if isApproved();
    }

    // editLocks
    match /editLocks/{docId} {
      allow read, write: if isApproved();
    }

    // watches
    match /watches/{docId} {
      allow read, write: if isApproved();
    }

    // users
    match /users/{uid} {
      // 본인 문서는 미승인(pending) 상태에서도 읽을 수 있어야 함 (승인 대기 화면)
      // 다른 사람 문서는 승인된 사용자만 조회 가능
      allow read: if isAuth() && (request.auth.uid == uid || isApproved());

      // 회원가입 시 본인 doc 최초 생성 — 안전한 기본값 강제
      //  - grade는 반드시 1 (담당자, 최저 등급) — 자기 자신을 관리자로 만들 수 없음
      //  - status는 반드시 'pending' — 자기 자신을 승인 처리할 수 없음
      //  ※ 첫 사용자 자동 셋업(auth.js의 grade=4/approved)은 이 규칙에 의해 차단됩니다.
      //    프로덕션에서는 이미 첫 사용자가 존재하므로 영향 없음.
      //    초기 부트스트랩이 필요한 경우 Firebase 콘솔에서 수동으로 첫 관리자 doc 시드 필요.
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.grade == 1
        && request.resource.data.status == 'pending';

      // 업데이트:
      //  - 본인이 본인 doc를 수정할 때는 grade/status 변경 금지 (권한 상승 차단)
      //  - 관리자(grade>=3)는 모든 필드 변경 가능 (등급/상태 변경 포함)
      allow update: if isAuth() && (
        (request.auth.uid == uid
          && request.resource.data.grade == resource.data.grade
          && request.resource.data.status == resource.data.status)
        || isAdmin()
      );

      // 회원 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // leaves — 연차 신청/내역
    match /leaves/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      // 본인(uid 필드 일치) 또는 관리자만 삭제
      allow delete: if isApproved() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
    }

    // leaveQuotas — 연차 한도
    match /leaveQuotas/{uid} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // attendance — 출퇴근
    match /attendance/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if false;
    }

    // activityLogs — 활동 로그 (감사 추적, 읽기만 허용)
    match /activityLogs/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if false;
    }

    // posts — 게시판
    match /posts/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isApproved() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.authorUid == request.auth.uid ||
        isAdmin()
      );
    }

    // comments — 모달 댓글
    match /comments/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      // 작성자(uid 필드) 또는 관리자(grade>=3)만 삭제 — 클라이언트 정책과 일치
      allow delete: if isApproved() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
    }

    // personalSchedules — 개인일정 (작성자 전용 데이터)
    match /personalSchedules/{doc} {
      allow read: if isApproved();
      allow create: if isApproved();
      // 작성자 본인만 수정/삭제 (관리자도 불가)
      allow update: if isApproved() && resource.data.createdBy == request.auth.uid;
      allow delete: if isApproved() && resource.data.createdBy == request.auth.uid;
    }

    // backups — 백업 데이터 (시스템 관리자 이상)
    match /backups/{type}/items/{itemId} {
      allow read: if isApproved();
      allow write: if isApproved() && userDoc(request.auth.uid).grade >= 4;
    }

    // salaries — 급여 (민감 정보)
    // read: 본인 doc 또는 관리자(grade>=3)
    // write: 관리자(grade>=3)만
    match /salaries/{doc} {
      allow read: if isApproved() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
