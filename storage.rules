rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 게시판 첨부파일 — 로그인된 사용자만 읽기/쓰기
    match /board/{postId}/{fileName} {
      allow read, write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
    // 기획 임시 이미지 — 로그인된 사용자만 읽기/쓰기
    match /plan/{planNo}/{fileName} {
      allow read, write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
